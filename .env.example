# Optional: improves AI ingredient lookup accuracy
OPENAI_API_KEY=sk-your-key-here

# Optional: override the OpenAI model used for ingredient lookup
# OPENAI_MODEL=gpt-4o-mini

# Required for Stripe donations (use test keys during development)
STRIPE_SECRET_KEY=sk_test_your-secret-key-here

# Optional: used for Stripe redirect URLs when not running on localhost
# NEXT_PUBLIC_APP_URL=http://localhost:3000

# Required for Supabase auth
# Use the Project URL only — NOT the REST endpoint
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here
